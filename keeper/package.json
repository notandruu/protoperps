{
  "name": "protoperps-keeper",
  "version": "0.1.0",
  "description": "Keeper bot for protoperps: oracle price feeds and liquidation monitoring",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "ts-node -r dotenv/config src/index.ts",
    "dev": "ts-node -r dotenv/config --watch src/index.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/web3.js": "^1.95.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
