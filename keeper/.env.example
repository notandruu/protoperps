# Path to the Solana keypair JSON file for the keeper authority.
# This must match the `authority` field stored in each OraclePrice account.
# Generate with: solana-keygen new --outfile keeper-keypair.json
KEYPAIR_PATH=/path/to/keeper-keypair.json

# Solana RPC endpoint. Use a paid endpoint (Helius, Triton) for production.
RPC_URL=https://api.devnet.solana.com

# How often to push prices (milliseconds). Default: 30000 (30 seconds).
# PRICE_PUSH_INTERVAL_MS=30000

# Rolling buffer size for in-memory TWAP computation. Default: 30 samples.
# TWAP_BUFFER_SIZE=30
